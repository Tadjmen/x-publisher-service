# Private password for this service's HTTP endpoints.
# This is NOT an X API key.
SERVICE_ACCESS_TOKEN=change-me

# X web session cookies from the account that will post/delete.
X_AUTH_TOKEN=
X_CT0=

# Authorization bearer token used by the X web client.
# Copy the "authorization: Bearer ..." value from an authenticated x.com web request.
X_WEB_BEARER_TOKEN=

# Optional network/proxy settings.
PROXY_URL=
BROWSER=chrome136

# Tweet text is compacted before sending. X long-form behavior depends on account status.
MAX_TWEET_CHARS=250

# Remote media download limit for media_urls.
MAX_MEDIA_DOWNLOAD_MB=50

# Disabled by default because HTTP callers could otherwise read arbitrary server files.
# Set true only when the API is private/local and you trust the caller.
ALLOW_LOCAL_MEDIA_PATHS=false
